{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Basementen Vault",
  "version": "0.1.0",
  "identifier": "com.basementen.vault",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Basementen Vault",
        "width": 1000,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false
  }
}
