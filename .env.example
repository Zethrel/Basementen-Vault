# Basementen Vault server configuration. Copy to .env and adjust.

# Public URL used inside e-mail links (your domain or Tailscale hostname).
BV_BASE_URL=https://vault.example.com

# Set to false once everyone in your household has an account.
BV_REGISTRATION_OPEN=true

# Enable ONLY when the server sits behind your own reverse proxy
# (Caddy/nginx); makes rate limiting use X-Forwarded-For.
BV_TRUST_PROXY=false

# --- E-mail delivery -------------------------------------------------------
# "console" logs mails to the server log (fine for VPN-only setups where you
# can read the log). "smtp" sends through a relay.
BV_MAILER=console

# For BV_MAILER=smtp, e.g. a Gmail app password or a Brevo/Mailgun free tier:
#BV_MAILER=smtp
#BV_SMTP_HOST=smtp.gmail.com
#BV_SMTP_PORT=587
#BV_SMTP_USERNAME=you@gmail.com
#BV_SMTP_PASSWORD=your-app-password
#BV_SMTP_FROM=you@gmail.com
